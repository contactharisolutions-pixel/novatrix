# ─── API URL ──────────────────────────────────────────────────
# The base URL of your backend API.
# In production, this should be your Vercel/Railway backend URL.
# Example: https://api.novatrix.vip
VITE_API_URL="http://localhost:5000"

# ─── Site URL ─────────────────────────────────────────────────
# The canonical public URL of this site (used for referral links).
# Must NOT have a trailing slash.
# In production set this to your live domain, e.g. https://novatrix.vip
# Leave blank in dev — window.location.origin will be used as fallback.
VITE_SITE_URL=""

# ─── Branding ─────────────────────────────────────────────────
VITE_SITE_NAME="Novatrix"
VITE_SITE_TAGLINE="Advanced Trading Solutions"
