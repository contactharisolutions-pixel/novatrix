# ─── Database ──────────────────────────────────────────────────
# Supabase Transaction Pooler URL (for serverless / Vercel deployments)
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ─── JWT ───────────────────────────────────────────────────────
# Generate strong secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your_super_secret_jwt_key_change_in_production_min_64_chars"
JWT_REFRESH_SECRET="your_refresh_secret_key_change_in_production_min_64_chars"
JWT_EXPIRES_IN="7d"

# ─── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Cron Job Security ─────────────────────────────────────────
# Secret shared between Vercel Cron / external scheduler and the /api/cron/run endpoint
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="your_cron_secret_key_here"

# ─── SMTP (Email notifications) ────────────────────────────────
# Leave blank in dev — Ethereal preview emails will be used automatically
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM='"Novatrix" <noreply@novatrix.vip>'

# ─── Supabase Storage (for KYC / file uploads) ────────────────
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# ─── Admin Seeder (used by: node scripts/seedAdmin.js) ─────────
SEED_ADMIN_NAME="Super Admin"
SEED_ADMIN_EMAIL="admin@novatrix.vip"
SEED_ADMIN_PASS="Admin@Novatrix2024!"

# ─── Frontend URL (for CORS & email links) ─────────────────────
CLIENT_URL="https://novatrix.vip"

# ─── CORS Allowed Origins (comma-separated, no spaces) ─────────
# Set this in Vercel env vars to the exact Vercel deployment URLs
CORS_ORIGINS="https://novatrix.vip,https://www.novatrix.vip"
