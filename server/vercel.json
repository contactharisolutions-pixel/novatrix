{
  "version": 2,
  "regions": ["bom1"],
  "builds": [
    { "src": "index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/index.js" }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    {
      "path": "/api/cron/run",
      "schedule": "30 18 * * *"
    }
  ]
}
